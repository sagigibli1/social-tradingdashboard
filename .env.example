# tradingdashboard - environment variables
# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored, so your secrets stay on your machine.

# REQUIRED - Apify API token. Used for BOTH the Twitter and Reddit ingestors.
# Get one at https://console.apify.com/account/integrations (free tier = $5/mo credit).
APIFY_API_TOKEN=

# OPTIONAL - Override the model used by the sentiment analyzer.
# Defaults to claude-opus-4-7 (whatever your Claude Code CLI is configured to use).
# Leave empty unless you specifically want a different model.
# CLAUDE_MODEL=
